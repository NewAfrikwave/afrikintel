# ============================================================
# Afrikintel — Production Environment Template
# Copy this file to .env and fill in your production values.
# ============================================================

# ----- Database -----
# PostgreSQL (recommended for production)
DATABASE_URL="postgresql://afrikintel:PASSWORD@localhost:5432/afrikintel?schema=public"

# SQLite (development only, not for production)
# DATABASE_URL="file:/home/z/my-project/db/custom.db"

# ----- Auth -----
# Generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Optional: Require authentication to view the dashboard
# REQUIRE_AUTH=1

# ----- GitHub OAuth (optional) -----
# Create an OAuth app at https://github.com/settings/developers
# Set the callback URL to: http://your-host/api/auth/callback/github
# GITHUB_ID=""
# GITHUB_SECRET=""

# ----- Email (SMTP) -----
# Configure these to enable email alerts
# smtp_host, smtp_port, smtp_user, smtp_pass, smtp_from are stored in the DB Settings table
# and can be configured via the Settings UI. These env vars are an alternative.
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="alerts@yourdomain.com"
# SMTP_PASS="app-specific-password"
# SMTP_FROM="alerts@yourdomain.com"

# ----- Twilio SMS (optional) -----
# Create an account at https://twilio.com
# TWILIO_SID=""
# TWILIO_TOKEN=""
# TWILIO_FROM="+15551234567"

# ----- Multi-region check workers -----
# Comma-separated list of regions this instance checks from
CHECK_REGIONS="us-east,eu-west,ap-southeast"

# ----- Engine -----
# Set to "true" to use simulated data (for demos / sales calls)
demoMode="false"

# Set to "1" on first production deploy to create demo@afrikintel.com / demo1234
SEED_DEMO="0"

# ----- Lemon Squeezy Billing (for SaaS mode) -----
# Create at lemonsqueezy.com
# LEMONSQUEEZY_API_KEY=""
# LEMONSQUEEZY_WEBHOOK_SECRET=""
# LS_STORE_ID=""
# LS_PRO_VARIANT_ID=""
# LS_BUSINESS_VARIANT_ID=""

# ----- Rate Limiting (optional, Upstash Redis) -----
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# ----- Error Tracking (optional, Sentry) -----
# SENTRY_DSN=""
# SENTRY_TRACES_SAMPLE_RATE="0.1"
